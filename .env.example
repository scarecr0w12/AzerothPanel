# ─── AzerothPanel – Docker Compose variables ──────────────────────────────────
# Copy to .env and adjust for your server before running: make docker-up
#
#   cp .env.example .env

# Path to your AzerothCore installation on the HOST machine.
# This directory is bind-mounted into the backend container so the panel can
# manage files, start/stop processes, and run the installer.
AC_PATH=/opt/azerothcore

# Path to your World of Warcraft 3.3.5a (12340) client on the HOST machine.
# This is used for extracting DBC, Maps, VMaps, and MMaps data.
# The directory is mounted read-write so extraction tools can write output.
# Leave as default if you don't have a client (use download method instead).
CLIENT_PATH=/root/clientdata

# Port the panel web UI is exposed on (default: 80).
PANEL_PORT=80

