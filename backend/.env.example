# ─── Panel Security ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Panel Admin Credentials ──────────────────────────────────────────────────
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASSWORD=admin

# ─── Panel Database (SQLite) ──────────────────────────────────────────────────
# Stores panel settings, audit logs, etc.
# In Docker the panel_data volume is mounted at /app, so panel.db lands there.
PANEL_DB_URL=sqlite+aiosqlite:///./panel.db

# ─── Docker-Mounted Paths ─────────────────────────────────────────────────────
# These are set in the root .env file and passed to the container.
# They are used as defaults for panel settings.
AC_PATH=/opt/azerothcore
CLIENT_PATH=/root/clientdata

# ─── CORS ─────────────────────────────────────────────────────────────────────
# CORS_ALLOW_ALL=true (default) lets the panel work from any IP without
# configuration — ideal for a self-hosted private server.
# Set to false and populate CORS_ORIGINS to restrict access.
CORS_ALLOW_ALL=true

# Only used when CORS_ALLOW_ALL=false:
# CORS_ORIGINS=["http://192.168.1.10","http://192.168.1.10:5173"]

# ─── NOTE ─────────────────────────────────────────────────────────────────────
# All AzerothCore paths, database credentials, and SOAP settings are
# configured through the panel's Settings page (stored in the SQLite database).
# They no longer live in this file.

